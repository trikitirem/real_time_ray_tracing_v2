@startuml 15_flow_record_rt
' Generate (z architecture/diagrams): plantuml -tsvg -tpng -o ../out 15_flow_record_rt.puml

skinparam shadowing false
skinparam roundcorner 10
skinparam backgroundColor #F4F6F9
skinparam ArrowColor #64748B
skinparam activity {
  BackgroundColor #FFFFFF
  BorderColor #CBD5E1
  FontColor #1E293B
}

title RayTracingFrameRecorder::record

start

:begin command buffer\n(Renderer);

:RayTracingFrameRecorder.record(cmd, ctx);

:pipelineBarrier2\n(layout swapchain + depth);

:beginRendering\n(dynamic rendering);

:setViewport / setScissor;

:bindPipeline(graphics);

if (camera_uniform_set?) then (tak)
  :bind camera descriptors;
endif

if (texture_uniform_set?) then (tak)
  :bind texture descriptors;
endif

if (scene_data valid?) then (tak)
  while (kazdy RtDrawItem?) is (tak)
    :pushConstants(model, material);
    :bindVertexBuffers;
    :bindIndexBuffer;
    :drawIndexed;
  endwhile (nie)
else (nie)
endif

:endRendering;

:pipelineBarrier2\n(swapchain -> present layout);

:end command buffer;

note right
  Struktury akceleracji (BLAS/TLAS)
  budowane przy load_scene,
  nie w record
end note

stop

@enduml
